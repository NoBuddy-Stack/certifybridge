# ──────────────────────────────────────────────────────────────
# ASTRA FORGE — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# Add all these in: Vercel Dashboard → Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

# ── Razorpay ──────────────────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_ prefix for testing, rzp_live_ for real payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Razorpay Webhook Secret (DIFFERENT from KEY_SECRET above)
# Get from: dashboard.razorpay.com → Settings → Webhooks → your webhook → Secret
# Register webhook URL: https://<your-vercel-domain>/api/webhook
# Select event: payment.captured
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get from: cloud.mongodb.com → Connect → Drivers
# Create a free M0 cluster in AWS Mumbai (ap-south-1)
# IMPORTANT: Use only alphanumeric chars in password (avoids URL-encoding issues)
# IMPORTANT: Allow 0.0.0.0/0 in Atlas Network Access (Vercel uses dynamic IPs)
# NOTE: Do NOT add maxPoolSize to this URI — it is set in lib/mongodb.js options
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/astra_forge?retryWrites=true&w=majority&appName=AstraForge

# ── Resend ────────────────────────────────────────────────────
# Get from: resend.com → API Keys
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── App Config ────────────────────────────────────────────────
# FROM_EMAIL must use a domain verified in your Resend dashboard
# During development you can use: onboarding@resend.dev
FROM_EMAIL=noreply@yourdomain.com
SUPPORT_EMAIL=contact@yourdomain.com
WHATSAPP_NUMBER=919999999999
COMPANY_NAME=Astra Forge

# ── CORS ──────────────────────────────────────────────────────
# Set to your production domain to restrict API access to that origin only
# Example: https://yourdomain.com
ALLOWED_ORIGIN=https://yourdomain.com

# ── Alerts (optional) ─────────────────────────────────────────
# Slack incoming webhook URL or any POST endpoint.
# If set, a message is fired when a MongoDB save fails after payment confirmation.
# This prevents silent data loss when Vercel log retention (1hr) expires.
# Leave blank to disable.
ALERT_WEBHOOK_URL=
